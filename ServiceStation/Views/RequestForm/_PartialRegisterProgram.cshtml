@model ServiceStation.Models.Common.Class
@{
    string _UserId = User.Claims.FirstOrDefault(s => s.Type == "UserId")?.Value;
    string _NickName = User.Claims.FirstOrDefault(s => s.Type == "NICKNAME")?.Value;
    string _Name = User.Claims.FirstOrDefault(s => s.Type == "Name")?.Value;
    string _SurName = User.Claims.FirstOrDefault(s => s.Type == "SurName")?.Value;
    string _Division = User.Claims.FirstOrDefault(s => s.Type == "Division")?.Value;
    string _Section = User.Claims.FirstOrDefault(s => s.Type == "Section")?.Value;

}
<link href="~/css/RequestForm/site.css" rel="stylesheet" />

<div style="text-align:left;width:100%;" class="center">



    <div id="f4New" style="@(@_UserId == @Model._ViewsvsServiceRequest.srRequestBy|| @_UserId == @Model._ViewsvsServiceRequest.srApproveEmpcode ? "" : "")">
        <div class="grid-container ">
            <div class="grid-item" style="text-align:left">

            </div>
            <div class="grid-item" style="text-align:right; margin-right:5px;">

            </div>
            <div class="grid-item " style="text-align:right; margin-right:5px;  @(Model._ViewsvsServiceRequest.srStep != 0
        ? "pointer-events:none; cursor:not-allowed; opacity:0.6;"
        : "")">
                @Html.DropDownListFor(m => m._ViewsearchPrg.program, (SelectList)ViewBag.formPgm, "กรุณาเลือกโปรแกรม", new { @class = "", id = "ipF4pgm", autocomplete = "off", required = "required", @style = "width:180px;height:30px;vertical-align: sub;font-size:12px" })
                <input type="text" style="width:100px;height:30px;vertical-align: sub;font-size:12px" placeholder="รหัสพนักงาน" id="txtF6empcode">
                <input type='button' class='Addtbsde button btnOrange' value='+ เพิ่ม New' style="width:80px;height:30px;vertical-align: sub; " onclick="btnaddNewF6('@Url.Action("SearchPersonal", "RequestForm")')">
            </div>
        </div>

        <select id="template_SelectPerEdit" style="display:none">
            <option value="">กรุณาเลือก</option>
            <option value="Editor">เปิดใช้งาน</option>
            <option value="No">ปิดใช้งาน</option>
        </select>
        <select id="template_SelectPerRead" style="display:none">
            <option value="">กรุณาเลือก</option>
            <option value="Read">เปิดใช้งาน</option>
            <option value="No">ปิดใช้งาน</option>
        </select>
        <select id="template_SelectPerDelete" style="display:none">
            <option value="">กรุณาเลือก</option>
            <option value="Delete">เปิดใช้งาน</option>
            <option value="No">ปิดใช้งาน</option>
        </select>
        <select id="template_SelectObject" style="display:none">
            <option value="">กรุณาเลือก</option>
            <option value="New" style="color:blue">ผู้ใช้ใหม่</option>
            <option value="Change" style="color:orange">เปลี่ยนสิทธิ์</option>
            <option value="Cancel" style="color:red">ยกเลิกผู้ใช้</option>
        </select>
        @{
            var statusListObject = new List<SelectListItem>{
            new SelectListItem { Text = "ผู้ใช้ใหม่", Value = "New" },
            new SelectListItem { Text = "เปลี่ยนสิทธิ์", Value = "Change" },
            new SelectListItem { Text = "ยกเลิกผู้ใช้", Value = "Cancel" }
            };

            var statusListPerEdit = new List<SelectListItem>{
            new SelectListItem { Text = "เปิดใช้งาน", Value = "Editor" },
            new SelectListItem { Text = "ปิดใช้งาน", Value = "No" }
            };

            var statusListPerRead = new List<SelectListItem>{
            new SelectListItem { Text = "เปิดใช้งาน", Value = "Read" },
            new SelectListItem { Text = "ปิดใช้งาน", Value = "No" }
            };

            var statusListPerDelete = new List<SelectListItem>{
            new SelectListItem { Text = "เปิดใช้งาน", Value = "Delete" },
            new SelectListItem { Text = "ปิดใช้งาน", Value = "No" }
            };



        }



        <table class="center" id="tbUsb" style="width:100%;">
            <tr align="Center">
                <td class="tbpurpleB" width="30px" rowspan="2" style="vertical-align: top;">No</td>
                <td class="tbpurpleB" width="80px" rowspan="2" style="font-size:10px;vertical-align: top;">Empcode</td>
                <td class="tbpurpleB" rowspan="2" style="width:80px;vertical-align: top;">ชื่อ</td>
                <td class="tbpurpleB" rowspan="2" style="width:80px;vertical-align: top;">นามสกุล</td>
                <td class="tbpurpleB" rowspan="2" style="width:80px;vertical-align: top;">ฝ่าย</td>
                <td class="tbpurpleB" rowspan="2" style="width:80px;vertical-align: top;">แผนก</td>
                <td class="tbpurpleB" rowspan="2"  width="80px" style="vertical-align: top;">ติดต่อ</td>
                <td class="tbpurpleB" rowspan="2" style="vertical-align: top;">Program Name</td>
                <td class="tbpurpleB" rowspan="2" width="80px" style="vertical-align: top;">ประเภทผู้ใช้งาน</td>
                <td class="tbpurpleB" colspan="3">Permission</td>
                <td class="tbpurpleB" rowspan="2" style="width:100px;">Remark</td>
                <td class="tbpurpleB" rowspan="2" width="30px" style=" @(Model._ViewsvsServiceRequest.srRequestBy == _UserId ? "":"display:none;")">
                    ลบ
                    @*<input type='button' class='RemoveRegis button btnOrange ' value='&#x274C' style="width:40px;height:20px">*@
                </td>
            </tr>
            <tr>
                @*<td class="tbpurple" style="font-size:9px">ผู้ใช้ใหม่</td>
                    <td class="tbpurple" style="font-size:9px">เปลี่ยนสิทธิ์</td>
                    <td class="tbpurple" style="font-size:9px">ยกเลิกผู้ใช้</td>*@
                <td class="tbgreen" style="font-size:9px">สร้าง/แก้ไข​<br /></td>
                <td class="tbgreen" style="font-size:9px">อ่านอย่างเดียว</td>
                <td class="tbgreen" style="font-size:9px">ลบเอกสาร</td>
            </tr>
            <tbody id="tableBodyItem">
                @if (Model._ViewsvsSDE_SystemRegister != null)
                {
                    var row = 0;
                    @for (var i = 0; i < Model._ViewsvsSDE_SystemRegister.Count; i++)
                    {
                        <tr>
                            <td style="vertical-align: top;">
                                @(row += 1)
                                <input type='text' class='vNo form-control ' min='0' style='width:70px;height:100%;font-size:10px;background-color:ghostwhite;display:none' asp-for="_ViewsvsSDE_SystemRegister[i].sysNo" readonly>
                            </td>
                            <td style="vertical-align: top;">
                                <textarea type='text' class='vEmpcode form-control ' min='0' style='width:100%;height:90%;font-size:10px;background-color:ghostwhite ;' asp-for="_ViewsvsSDE_SystemRegister[i].sysEmpCode" readonly></textarea>

                                @*<input type='text' class='vEmpcode form-control ' min='0' style='width:100%;height:90%;font-size:10px;background-color:ghostwhite ;' asp-for="_ViewsvsSDE_SystemRegister[i].sysEmpCode" readonly>*@
                            </td>
                            <td style="vertical-align: top;">
                                <textarea type='text' class='vName form-control ' min='0' style='width:100%;height:90%;font-size:10px;background-color:ghostwhite ;' asp-for="_ViewsvsSDE_SystemRegister[i].sysName" readonly></textarea>
                                @*<input type='text' class='vName form-control ' min='0' style='width:100%;height:90%;font-size:10px;background-color:ghostwhite ;' asp-for="_ViewsvsSDE_SystemRegister[i].sysName" readonly>*@
                            </td>
                            <td style="vertical-align: top;">
                                <textarea type='text' class='vLastName form-control ' min='0' style='width:100%;height:90%;font-size:10px;background-color:ghostwhite ;' asp-for="_ViewsvsSDE_SystemRegister[i].sysLastName" readonly></textarea>
                                @*<input type='text' class='vLastName form-control ' min='0' style='width:100%;height:90%;font-size:10px;background-color:ghostwhite ;' asp-for="_ViewsvsSDE_SystemRegister[i].sysLastName" readonly>*@
                            </td>
                            <td style="vertical-align: top;">
                                <textarea type='text' class='vDeptCode form-control ' min='0' style='width:100%;height:90%;font-size:10px;background-color:ghostwhite ;' asp-for="_ViewsvsSDE_SystemRegister[i].sysDeptCode" readonly></textarea>
                                @*<input type='text' class='vDeptCode form-control ' min='0' style='width:60px;height:100%;font-size:10px;background-color:ghostwhite ;' asp-for="_ViewsvsSDE_SystemRegister[i].sysDeptCode" readonly>*@
                            </td>
                            <td style="vertical-align: top;">
                                <textarea type='text' class='vSectCode form-control ' min='0' style='width:100%;height:90%;font-size:10px;background-color:ghostwhite ;' asp-for="_ViewsvsSDE_SystemRegister[i].sysDeptCode" readonly></textarea>

                                @*<input type='text' class='vSectCode form-control ' min='0' style='width:60px;height:100%;font-size:10px;background-color:ghostwhite ;' asp-for="_ViewsvsSDE_SystemRegister[i].sysSectCode" readonly>*@
                            </td>
                            <td style="vertical-align: top;">
                                <textarea type='text' class='vIntercomNo form-control ' min='0' style='width:100%;height:90%;font-size:10px;background-color:ghostwhite ;' asp-for="_ViewsvsSDE_SystemRegister[i].sysIntercomNo" readonly></textarea>

                                @*<input type='text' class='vIntercomNo form-control ' min='0' style='width:50px;height:100%;font-size:10px;background-color:ghostwhite ;' asp-for="_ViewsvsSDE_SystemRegister[i].sysIntercomNo" readonly>*@
                            </td>
                            <td style="vertical-align: top;">
                                <textarea type='text' class='vProgramName form-control ' min='0' style='width:100%;height:90%;font-size:10px;background-color:ghostwhite ;' asp-for="_ViewsvsSDE_SystemRegister[i].sysProgramName" readonly></textarea>

                                @*<input type='text' class='vProgramName form-control ' min='0' style='width:100%;height:100%;font-size:10px;background-color:ghostwhite;' asp-for="_ViewsvsSDE_SystemRegister[i].sysProgramName" readonly>*@
                            </td>
                            <td style="vertical-align: top;">
                                @Html.DropDownListFor(m => m._ViewsvsSDE_SystemRegister[i].sysObject, statusListObject, "กรุณาเลือก", new { @class = "form-control vObject", id = "ipStatus", autocomplete = "off", @style = "width:100%;font-size:10px;background-color:aliceblue;font-weight:700;height:40px;", disabled = "disabled" })
                            </td>
                            <td style="vertical-align: top;">
                                @Html.DropDownListFor(m => m._ViewsvsSDE_SystemRegister[i].sysPermissionEditor, statusListPerEdit, "กรุณาเลือก", new { @class = "form-control vPermissionEditor", id = "ipEdit", autocomplete = "off", @style = "width:100%;font-size:10px;background-color:aliceblue;font-weight:700;height:40px;", disabled = "disabled" })
                            </td>
                            <td style="vertical-align: top;">
                                @Html.DropDownListFor(m => m._ViewsvsSDE_SystemRegister[i].sysPermissionRead, statusListPerRead, "กรุณาเลือก", new { @class = "form-control vPermissionRead", id = "ipread", autocomplete = "off", @style = "width:100%;font-size:10px;background-color:aliceblue;font-weight:700;height:40px;", disabled = "disabled" })
                            </td>
                            <td style="vertical-align: top;">
                                @Html.DropDownListFor(m => m._ViewsvsSDE_SystemRegister[i].sysPermissionDelete, statusListPerDelete, "กรุณาเลือก", new { @class = "form-control vPermissionDelete", id = "ipread", autocomplete = "off", @style = "width:100%;font-size:10px;background-color:aliceblue;font-weight:700;height:40px;", disabled = "disabled" })
                            </td>
                            <td><textarea class='vRemark form-control ' style='font-size: 10px; max-width: 100%; height: 80px;' asp-for="_ViewsvsSDE_SystemRegister[i].sysRemark"></textarea> </td>
                            <td align='Center' style=" @(Model._ViewsvsServiceRequest.srRequestBy == _UserId ? "":"display:none;")"><input type='button' class='RemoveRow' value='&#x274C'></td>
                        </tr>
                    }
                }


            </tbody>









        </table>


    </div>
    <br />
    <div style="width:100%">

        <input name="files" type="file" id="files" multiple="" class="button " style="width:300px;margin-right:20px;@(@_UserId == @Model._ViewsvsServiceRequest.srRequestBy|| @_UserId == @Model._ViewsvsServiceRequest.srApproveEmpcode ? "" : "pointer-events: none;")">
        <button type="button" class="button notification" style="width:140px; height:28px;background-color:#7286D3" data-bs-dismiss="modal" id="btnfile">
            <img src="~/images/open-folder.png" style="width:25px;height:25px;padding-right:5px;margin-right:8px">
            @{ var fileCount = Model._ListViewAttachmentUser?.Count() ?? 0;}

            เปิดไฟล์แนบ @fileCount ไฟล์
            @if (@fileCount > 0)
            {<span class="badge">@fileCount</span>}
        </button>
        <span class="text-red" style="font-size:13px;margin-left:10px"> กรณีขอใช้งานเกิน 8 คน รบกวนแนบไฟล์</span>
    </div>
</div>



